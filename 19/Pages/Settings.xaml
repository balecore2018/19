<Page x:Class="_19.Pages.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_19.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="410" d:DesignWidth="900.509"
      Title="Settings">

    <Grid Background="White">
        <Grid x:Name="gr_header" Height="60" Margin="0,0,0.4,0" VerticalAlignment="Top" Background="Black">
            <Label Content="Настройки" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"
                   Foreground="White" FontWeight="Bold" FontSize="20"/>
        </Grid>

        <Grid Margin="0,60,0.4,-0.4">
            <Border BorderBrush="Black" BorderThickness="1" Height="54" Margin="10,21,10.4,0" VerticalAlignment="Top">
                <Grid>
                    <TextBlock x:Name="tb_database" Margin="9,19,0,0" TextWrapping="Wrap" Text="" HorizontalAlignment="Left" Width="615" Height="23" VerticalAlignment="Top"/>
                    <Button Click="OpenDataBaza" Content="Выбрать" HorizontalAlignment="Right" Margin="0,19,129,0"
                            VerticalAlignment="Top" Width="120" Height="23"/>
                </Grid>
            </Border>

            <Label Content="База данных: " Margin="20,10,0,0" VerticalAlignment="Top"
                   Background="White" HorizontalAlignment="Left" Width="84"/>
            <Border BorderBrush="Black" BorderThickness="1" Height="45" Margin="10,96,10,0" VerticalAlignment="Top">
                <Grid>
                    <ComboBox SelectionChanged="SelectScreenResolution" Margin="10,0,128,0" VerticalAlignment="Center">
                        <TextBlock>800 x 450</TextBlock>
                        <TextBlock>800 x 600</TextBlock>
                        <TextBlock>1024 x 768</TextBlock>
                        <TextBlock>1152 x 864</TextBlock>
                        <TextBlock>1280 x 600</TextBlock>
                        <TextBlock>1280 x 720</TextBlock>
                        <TextBlock>1280 x 768</TextBlock>
                        <TextBlock>1280 x 800</TextBlock>
                        <TextBlock>1280 x 960</TextBlock>
                        <TextBlock>1280 x 1024</TextBlock>
                        <TextBlock>1360 x 768</TextBlock>
                        <TextBlock>1366 x 768</TextBlock>
                        <TextBlock>1400 x 1050</TextBlock>
                        <TextBlock>1400 x 900</TextBlock>
                        <TextBlock>1600 x 900</TextBlock>
                        <TextBlock>1680 x 900</TextBlock>
                        <TextBlock>1680 x 1050</TextBlock>
                        <TextBlock>1920 x 1080</TextBlock>
                    </ComboBox>
                </Grid>
            </Border>

            <Label Content="Разрешение: " HorizontalAlignment="Left" Margin="20,80,0,0" VerticalAlignment="Top" Background="White"/>
            <Border BorderBrush="Black" BorderThickness="1" Height="100" Margin="10,160,10,0" VerticalAlignment="Top">
                <Grid>
                    <Grid Margin="0.2,0.2,-0.4,51.2">
                        <Label Content="Цвет приложения: " HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <Grid x:Name="gr_appliacation" Margin="127,0,0,0" Background="Black" Height="27" VerticalAlignment="Center" HorizontalAlignment="Left" Width="49"></Grid>
                        <Button Click="SelectColorApplication" Content="Выбрать" HorizontalAlignment="Left" Margin="182,0,0,0" VerticalAlignment="Center" Width="150" Height="26"/>
                    </Grid>

                    <Grid Margin="0,41,-0.2,10.4">
                        <Label Content="Цвет текста: " HorizontalAlignment="Left" Margin="9,0,0,0" VerticalAlignment="Center"/>
                        <Grid Margin="127,0,0,0" Background="Black" Height="27" VerticalAlignment="Center" HorizontalAlignment="Left" Width="49"></Grid>
                        <Button Click="SelectColorText" Content="Выбрать" HorizontalAlignment="Left" Margin="182,0,0,0" VerticalAlignment="Center" Width="150" Height="26"/>
                    </Grid>
                </Grid>
            </Border>

            <Label Content="Цвета: " HorizontalAlignment="Left" Margin="20,146,0,0" VerticalAlignment="Top" Background="White"/>
            <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Left" Height="63" Margin="10,277,0,0" VerticalAlignment="Top" Width="762">
                <Grid>
                    <Label Content="Segoe UI" Margin="10,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="614"/>
                    <Button Click="SelectFonts" Content="Выбрать" HorizontalAlignment="Left" Margin="629,10,0,0" VerticalAlignment="Top" Width="121" Height="25"/>
                </Grid>
            </Border>
            <Label Content="Шрифт: " HorizontalAlignment="Left" Margin="20,265,0,0" VerticalAlignment="Top" Background="White"/>
        </Grid>
    </Grid>
</Page>
